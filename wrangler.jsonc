{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "prabhavalabs",
  "compatibility_date": "2026-07-01",
  "routes": [
    { "pattern": "prabhavalabs.com", "custom_domain": true },
    { "pattern": "www.prabhavalabs.com", "custom_domain": true }
  ],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page"
  }
}
