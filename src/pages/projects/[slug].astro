---
import { getCollection, render } from 'astro:content';
import { ArrowLeft, ArrowUpRight } from 'lucide-react';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar';
import Footer from '../../components/Footer';
import Starfield from '../../components/Starfield';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((p) => ({ params: { slug: p.id }, props: { project: p } }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const d = project.data;

const statusStyle: Record<string, string> = {
  active: 'text-emerald-300/80 border-emerald-300/20',
  incubating: 'text-amber-300/80 border-amber-300/20',
  archived: 'text-white/40 border-white/10',
};
---

<Layout title={`${d.title} — ප්‍රභව Labs`} description={d.description}>
  <Navbar client:load currentPath="/projects" />

  <header class="relative overflow-hidden px-6 pb-14 pt-44 md:pt-52">
    <Starfield client:load density={90} />
    <div
      class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top,_rgba(124,111,212,0.1)_0%,_transparent_65%)]"
    >
    </div>
    <div class="relative mx-auto max-w-3xl">
      <a
        href="/projects"
        class="mb-10 inline-flex items-center gap-2 text-sm text-white/50 transition-colors hover:text-white"
      >
        <ArrowLeft size={14} /> All projects
      </a>

      <div class="mb-6 flex flex-wrap items-center gap-3">
        <span
          class={`rounded-full border px-3 py-1 text-[11px] uppercase tracking-widest ${statusStyle[d.status]}`}
        >
          {d.status}
        </span>
        {d.tags.map((t) => (
          <span class="rounded-full border border-white/10 px-3 py-1 text-xs text-white/40">{t}</span>
        ))}
      </div>

      <h1 class="font-serif-display text-5xl leading-[1.05] tracking-tight text-white md:text-7xl">
        {d.title}
      </h1>
      <p class="mt-4 text-lg text-white/50">{d.tagline}</p>

      <div class="mt-8 flex flex-wrap gap-4">
        {d.repo && (
          <a
            href={d.repo}
            target="_blank"
            rel="noreferrer"
            class="liquid-glass flex items-center gap-2 rounded-full px-6 py-2.5 text-sm font-medium text-white transition-colors hover:bg-white/5"
          >
            View source <ArrowUpRight size={15} />
          </a>
        )}
        {d.link && (
          <a
            href={d.link}
            target="_blank"
            rel="noreferrer"
            class="rounded-full bg-white px-6 py-2.5 text-sm font-semibold text-black"
          >
            Visit project
          </a>
        )}
      </div>
    </div>
  </header>

  <main class="px-6 pb-28">
    <article class="prose-dark mx-auto max-w-3xl border-t border-white/10 pt-12">
      <Content />
    </article>
  </main>

  <Footer client:visible />
</Layout>
