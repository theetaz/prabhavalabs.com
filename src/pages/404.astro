---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — ප්‍රභව Labs">
  <main class="flex min-h-screen flex-col items-center justify-center px-6 text-center">
    <h1 class="font-serif-display text-8xl italic text-white/80">404</h1>
    <p class="mt-4 text-sm text-white/50">This page hasn't originated yet.</p>
    <a
      href="/"
      class="liquid-glass mt-8 rounded-full px-8 py-3 text-sm font-medium text-white"
    >
      Back to origin
    </a>
  </main>
</Layout>
