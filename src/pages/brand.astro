---
import { Download } from 'lucide-react';
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer';
import Starfield from '../components/Starfield';

const colors = [
  { name: 'Origin Black', hex: '#000000', use: 'Backgrounds — everything lives on black', text: 'text-white' },
  { name: 'Deep Space', hex: '#0A0A14', use: '3D surfaces, panels', text: 'text-white' },
  { name: 'Pure White', hex: '#FFFFFF', use: 'Headlines, logo, primary actions', text: 'text-black' },
  { name: 'Prabhava Violet', hex: '#A78BFA', use: 'Accent — arcs, links, highlights', text: 'text-black' },
  { name: 'Soft Violet', hex: '#C4B5FD', use: 'Gradients, prose links', text: 'text-black' },
  { name: 'Deep Violet', hex: '#5B21B6', use: 'Particle edges, depth', text: 'text-white' },
  { name: 'Signal Emerald', hex: '#6EE7B7', use: 'Status: active', text: 'text-black' },
  { name: 'Signal Amber', hex: '#FCD34D', use: 'Status: incubating', text: 'text-black' },
];

const downloads = [
  { label: 'Origin mark (SVG)', href: '/brand/prabhava-mark.svg' },
  { label: 'Wordmark (SVG)', href: '/brand/prabhava-wordmark.svg' },
  { label: 'Wordmark PNG — transparent', href: '/brand/prabhava-wordmark.png' },
  { label: 'Wordmark PNG — on black', href: '/brand/prabhava-wordmark-black.png' },
];

const socialAssets = [
  { label: 'Profile avatar — 1024×1024', href: '/brand/social/profile-avatar.png', img: '/brand/social/profile-avatar.png' },
  { label: 'X header — 1500×500', href: '/brand/social/x-header.png', img: '/brand/social/x-header.png' },
  { label: 'LinkedIn banner — 1584×396', href: '/brand/social/linkedin-banner.png', img: '/brand/social/linkedin-banner.png' },
  { label: 'Square cover — 1080×1080', href: '/brand/social/square-cover.png', img: '/brand/social/square-cover.png' },
];

const bios = [
  {
    platform: 'X (Twitter)',
    note: 'Bio, 160 character limit',
    text: 'Independent open-source studio from Sri Lanka. Every tool ships with its story: Sinhala subtitles for YouTube, outage maps, population APIs. ප්‍රභව = origin.',
  },
  {
    platform: 'LinkedIn',
    note: 'Tagline + about section',
    text: 'Independent open-source studio. Built in public from Sri Lanka.\n\nප්‍රභව (prabhava) is the Sanskrit word for origin. Prabhava Labs is where one developer builds open-source tools and publishes the full story behind each one: the problem, the dead ends, and the engineering that finally worked. Current projects include Vidura (Sinhala subtitles for YouTube), GridPulse (crowdsourced power-outage tracking), and GeoPop (a population and geocoding API). All source, all stories: prabhavalabs.com',
  },
  {
    platform: 'Instagram',
    note: 'Bio, 150 character limit',
    text: 'ප්‍රභව = where ideas take origin\nOpen-source tools, built in public 🇱🇰\nStories and code below\nprabhavalabs.com',
  },
  {
    platform: 'Handle (all platforms)',
    note: 'Keep it identical everywhere',
    text: '@prabhavalabs',
  },
];
---

<Layout
  title="Brand & Assets — ප්‍රභව Labs"
  description="Prabhava Labs brand guidelines: logo downloads, color palette, typography, and usage rules."
>
  <Navbar client:load currentPath="/brand" />

  <header class="relative overflow-hidden px-6 pb-10 pt-44 md:pt-52">
    <Starfield client:load density={110} />
    <div
      class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top,_rgba(124,111,212,0.1)_0%,_transparent_65%)]"
    >
    </div>
    <div class="relative mx-auto max-w-6xl">
      <p class="mb-6 text-xs font-medium uppercase tracking-[0.35em] text-white/40">Brand & assets</p>
      <h1 class="font-serif-display max-w-3xl text-5xl leading-[1.05] tracking-tight text-white md:text-7xl">
        One mark, <em class="italic text-white/60">one origin.</em>
      </h1>
      <p class="mt-6 max-w-xl text-sm leading-relaxed text-white/50 md:text-base">
        Everything needed to represent ප්‍රභව Labs — the origin mark, wordmark, palette, and type.
        Free to use when writing about or linking to our projects.
      </p>
    </div>
  </header>

  <main class="px-6 pb-28">
    <div class="mx-auto max-w-6xl space-y-24">
      <!-- Logo -->
      <section>
        <h2 class="font-serif-display mb-8 text-3xl tracking-tight text-white md:text-4xl">
          The mark
        </h2>
        <div class="grid gap-6 md:grid-cols-2">
          <div class="liquid-glass flex aspect-video items-center justify-center rounded-3xl">
            <img src="/brand/prabhava-mark.svg" alt="Prabhava Labs origin mark" class="h-40 w-40" />
          </div>
          <div class="liquid-glass flex aspect-video items-center justify-center rounded-3xl p-10">
            <img
              src="/brand/prabhava-wordmark.png"
              alt="ප්‍රභව Labs wordmark"
              class="w-full max-w-md"
            />
          </div>
        </div>
        <p class="mt-6 max-w-2xl text-sm leading-relaxed text-white/50">
          The origin mark is a point radiating outward — ප්‍රභව, the place something begins. The
          wordmark pairs Noto Serif Sinhala with Instrument Serif italic.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          {downloads.map((d) => (
            <a
              href={d.href}
              download
              class="liquid-glass flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-medium text-white transition-colors hover:bg-white/5"
            >
              <Download size={14} />
              {d.label}
            </a>
          ))}
        </div>
      </section>

      <!-- Colors -->
      <section>
        <h2 class="font-serif-display mb-8 text-3xl tracking-tight text-white md:text-4xl">
          Color
        </h2>
        <div class="grid grid-cols-2 gap-4 md:grid-cols-4">
          {colors.map((c) => (
            <div class="liquid-glass overflow-hidden rounded-2xl">
              <div
                class={`flex h-28 items-end p-3 ${c.text}`}
                style={`background:${c.hex}`}
              >
                <span class="font-mono text-xs opacity-80">{c.hex}</span>
              </div>
              <div class="p-4">
                <p class="text-sm font-medium text-white">{c.name}</p>
                <p class="mt-1 text-xs leading-relaxed text-white/40">{c.use}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Typography -->
      <section>
        <h2 class="font-serif-display mb-8 text-3xl tracking-tight text-white md:text-4xl">
          Typography
        </h2>
        <div class="grid gap-6 md:grid-cols-3">
          <div class="liquid-glass rounded-3xl p-8">
            <p class="font-serif-display text-5xl text-white">Aa <em class="italic">Aa</em></p>
            <p class="mt-4 text-sm font-medium text-white">Instrument Serif</p>
            <p class="mt-1 text-xs leading-relaxed text-white/40">
              Display headlines & emphasis. Italic carries the voice — one italic phrase per
              headline.
            </p>
          </div>
          <div class="liquid-glass rounded-3xl p-8">
            <p class="font-sinhala text-5xl text-white">ප්‍රභව</p>
            <p class="mt-4 text-sm font-medium text-white">Noto Serif Sinhala</p>
            <p class="mt-1 text-xs leading-relaxed text-white/40">
              The Sinhala wordmark and any Sinhala copy. Weight 400–500.
            </p>
          </div>
          <div class="liquid-glass rounded-3xl p-8">
            <p class="text-5xl font-medium text-white">Aa</p>
            <p class="mt-4 text-sm font-medium text-white">System Sans</p>
            <p class="mt-1 text-xs leading-relaxed text-white/40">
              Body copy, UI labels, and navigation — native system font stack for speed.
            </p>
          </div>
        </div>
      </section>

      <!-- Social kit -->
      <section>
        <h2 class="font-serif-display mb-8 text-3xl tracking-tight text-white md:text-4xl">
          Social kit
        </h2>
        <p class="mb-8 max-w-2xl text-sm leading-relaxed text-white/50">
          Ready-to-upload profile and cover images for every major platform, plus the exact bios.
          Same mark, same palette, same voice everywhere.
        </p>
        <div class="grid gap-6 md:grid-cols-2">
          {socialAssets.map((a) => (
            <div class="liquid-glass overflow-hidden rounded-3xl">
              <div class="flex max-h-56 items-center justify-center overflow-hidden bg-black">
                <img src={a.img} alt={a.label} class="w-full object-contain" />
              </div>
              <div class="flex items-center justify-between p-5">
                <p class="text-sm text-white/70">{a.label}</p>
                <a
                  href={a.href}
                  download
                  class="liquid-glass flex items-center gap-2 rounded-full px-4 py-2 text-xs font-medium text-white transition-colors hover:bg-white/5"
                >
                  <Download size={13} /> Download
                </a>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-10 grid gap-6 md:grid-cols-2">
          {bios.map((b) => (
            <div class="liquid-glass rounded-3xl p-6 md:p-8">
              <div class="mb-3 flex items-baseline justify-between">
                <p class="text-sm font-medium text-white">{b.platform}</p>
                <p class="text-xs text-white/35">{b.note}</p>
              </div>
              <p class="whitespace-pre-line text-sm leading-relaxed text-white/60 select-all">
                {b.text}
              </p>
            </div>
          ))}
        </div>
      </section>

      <!-- Usage -->
      <section>
        <h2 class="font-serif-display mb-8 text-3xl tracking-tight text-white md:text-4xl">
          Usage
        </h2>
        <div class="grid gap-6 md:grid-cols-2">
          <div class="liquid-glass rounded-3xl p-8">
            <p class="mb-4 text-xs uppercase tracking-widest text-emerald-300/80">Do</p>
            <ul class="space-y-3 text-sm leading-relaxed text-white/60">
              <li>Use the mark on black or very dark backgrounds</li>
              <li>Keep clear space around the mark equal to its inner ring</li>
              <li>Use Prabhava Violet only as an accent, never as a fill for large areas</li>
              <li>Pair the wordmark fonts exactly as provided</li>
            </ul>
          </div>
          <div class="liquid-glass rounded-3xl p-8">
            <p class="mb-4 text-xs uppercase tracking-widest text-amber-300/80">Don't</p>
            <ul class="space-y-3 text-sm leading-relaxed text-white/60">
              <li>Recolor, rotate, or add effects to the mark</li>
              <li>Place the logo on light or photographic backgrounds</li>
              <li>Stretch the wordmark or change its letter spacing</li>
              <li>Imply endorsement — the mark identifies our projects only</li>
            </ul>
          </div>
        </div>
      </section>
    </div>
  </main>

  <Footer client:visible />
</Layout>
