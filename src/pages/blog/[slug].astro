---
import { getCollection, render } from 'astro:content';
import { ArrowLeft } from 'lucide-react';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar';
import Footer from '../../components/Footer';
import Starfield from '../../components/Starfield';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((p) => ({ params: { slug: p.id }, props: { post: p } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const d = post.data;

// Find this post's counterpart in the other language (linked either way).
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const translation = allPosts.find(
  (p) => p.data.translationOf === post.id || p.id === d.translationOf
);

const fmt = d.date.toLocaleDateString(d.lang === 'si' ? 'si-LK' : 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout title={`${d.title} — ප්‍රභව Labs`} description={d.description}>
  <Navbar client:load currentPath="/blog" />

  <header class="relative overflow-hidden px-6 pb-12 pt-44 md:pt-52">
    <Starfield client:load density={80} />
    <div
      class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top,_rgba(124,111,212,0.1)_0%,_transparent_65%)]"
    >
    </div>
    <div class="relative mx-auto max-w-3xl">
      <a
        href="/blog"
        class="mb-10 inline-flex items-center gap-2 text-sm text-white/50 transition-colors hover:text-white"
      >
        <ArrowLeft size={14} /> All posts
      </a>

      <div class="mb-6 flex flex-wrap items-center gap-3 text-sm text-white/40">
        <time>{fmt}</time>
        {d.tags.map((t) => (
          <span class="rounded-full border border-white/10 px-3 py-1 text-xs text-white/40">{t}</span>
        ))}
        {translation && (
          <span class="liquid-glass flex items-center gap-1 rounded-full p-1 text-xs">
            <span
              class={`rounded-full px-3 py-1 ${d.lang === 'en' ? 'bg-white text-black' : 'text-white/60'}`}
            >
              {d.lang === 'en' ? 'English' : <a href={`/blog/${translation.id}`}>English</a>}
            </span>
            <span
              class={`font-sinhala rounded-full px-3 py-1 ${d.lang === 'si' ? 'bg-white text-black' : 'text-white/60'}`}
            >
              {d.lang === 'si' ? 'සිංහල' : <a href={`/blog/${translation.id}`}>සිංහල</a>}
            </span>
          </span>
        )}
      </div>

      <h1 class="font-serif-display text-4xl leading-[1.1] tracking-tight text-white md:text-6xl">
        {d.title}
      </h1>
      <p class="mt-5 text-lg leading-relaxed text-white/50">{d.description}</p>
    </div>
  </header>

  <main class="px-6 pb-28">
    <article class="prose-dark mx-auto max-w-3xl border-t border-white/10 pt-12">
      <Content />
    </article>
  </main>

  <Footer client:visible />
</Layout>
