---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar';
import Footer from '../../components/Footer';
import Starfield from '../../components/Starfield';

// The index lists English posts; Sinhala versions are reached through the
// language switcher on each post.
const posts = (
  await getCollection('blog', ({ data }) => !data.draft && data.lang === 'en')
).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = (date: Date) =>
  date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<Layout
  title="Engineering Blog — ප්‍රභව Labs"
  description="Write-ups, deep dives, and the stories behind Prabhava Labs' open-source projects."
>
  <Navbar client:load currentPath="/blog" />

  <header class="relative overflow-hidden px-6 pb-10 pt-44 md:pt-52">
    <Starfield client:load density={130} />
    <div
      class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top,_rgba(124,111,212,0.1)_0%,_transparent_65%)]"
    >
    </div>
    <div class="relative mx-auto max-w-6xl">
      <p class="mb-6 text-xs font-medium uppercase tracking-[0.35em] text-white/40">
        Engineering blog
      </p>
      <h1 class="font-serif-display max-w-3xl text-5xl leading-[1.05] tracking-tight text-white md:text-7xl">
        Notes from <em class="italic text-white/60">the origin.</em>
      </h1>
      <p class="mt-6 max-w-xl text-sm leading-relaxed text-white/50 md:text-base">
        Deep dives, decision logs, and honest write-ups from building open-source software.
      </p>
    </div>
  </header>

  <main class="px-6 pb-28 pt-8">
    <div class="mx-auto max-w-6xl">
      {
        posts.length === 0 ? (
          <p class="text-white/40">First post coming soon.</p>
        ) : (
          <ul class="divide-y divide-white/10 border-t border-white/10">
            {posts.map((post) => (
              <li>
                <a
                  href={`/blog/${post.id}`}
                  class="group grid gap-2 py-8 transition-colors md:grid-cols-[10rem_1fr_auto] md:items-baseline md:gap-8"
                >
                  <time class="text-sm text-white/35">{fmt(post.data.date)}</time>
                  <div>
                    <h2 class="font-serif-display text-2xl tracking-tight text-white/90 transition-colors group-hover:text-white md:text-3xl">
                      {post.data.title}
                    </h2>
                    <p class="mt-2 max-w-2xl text-sm leading-relaxed text-white/45">
                      {post.data.description}
                    </p>
                  </div>
                  <div class="hidden gap-2 md:flex">
                    {post.data.tags.slice(0, 2).map((t) => (
                      <span class="rounded-full border border-white/10 px-3 py-1 text-xs text-white/40">
                        {t}
                      </span>
                    ))}
                  </div>
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </main>

  <Footer client:visible />
</Layout>
